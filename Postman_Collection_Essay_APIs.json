{
  "info": {
    "name": "LLM Essay Evaluation APIs",
    "description": "Complete collection for essay submission, evaluation, and user dashboard APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "User Registration",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Test\",\n  \"last_name\": \"User\",\n  \"type\": \"e\",\n  \"email\": \"test@yopmail.com\",\n  \"password\": \"testpass123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/backend/api/v1/users/",
              "host": ["{{base_url}}"],
              "path": ["backend", "api", "v1", "users", ""]
            },
            "description": "Register a new user account"
          }
        },
        {
          "name": "User Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@yopmail.com\",\n  \"password\": \"testpass123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/backend/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["backend", "api", "v1", "auth", "login"]
            },
            "description": "Login user and get JWT token"
          }
        }
      ]
    },
    {
      "name": "Essay Management",
      "item": [
        {
          "name": "Submit Essay for Evaluation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"essay_text\": \"Indian politics is one of the most complex and vibrant political systems in the world. As the largest democracy, India operates under a constitutional framework that ensures representation, rights, and governance for over a billion people. The parliamentary system consists of the Lok Sabha and Rajya Sabha, with the Prime Minister as the executive head. Elections are conducted by the Election Commission of India, ensuring democratic participation through Electronic Voting Machines. Despite challenges like corruption and regional disparities, India's democracy remains resilient with peaceful transitions of power and an engaged civil society.\",\n  \"title\": \"Indian Democracy: Challenges and Resilience\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/backend/api/v1/essays/submit",
              "host": ["{{base_url}}"],
              "path": ["backend", "api", "v1", "essays", "submit"]
            },
            "description": "Submit an essay for AI-powered evaluation"
          }
        },
        {
          "name": "Get Essay History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/backend/api/v1/essays/history?limit=10&offset=0",
              "host": ["{{base_url}}"],
              "path": ["backend", "api", "v1", "essays", "history"],
              "query": [
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Number of essays to return (max 100)"
                },
                {
                  "key": "offset",
                  "value": "0",
                  "description": "Number of essays to skip"
                }
              ]
            },
            "description": "Get user's essay submission history with pagination"
          }
        },
        {
          "name": "Get User Dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/backend/api/v1/essays/dashboard",
              "host": ["{{base_url}}"],
              "path": ["backend", "api", "v1", "essays", "dashboard"]
            },
            "description": "Get user dashboard with statistics and recent essays"
          }
        }
      ]
    },
    {
      "name": "Additional Authentication APIs",
      "item": [
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@yopmail.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/backend/api/v1/auth/forgot-password",
              "host": ["{{base_url}}"],
              "path": ["backend", "api", "v1", "auth", "forgot-password"]
            },
            "description": "Send password reset link to user's email"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"reset_token_here\",\n  \"new_password\": \"newpassword123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/backend/api/v1/auth/reset-password",
              "host": ["{{base_url}}"],
              "path": ["backend", "api", "v1", "auth", "reset-password"]
            },
            "description": "Reset user password using reset token"
          }
        },
        {
          "name": "Email Verification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"verification_token_here\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/backend/api/v1/auth/verify-email",
              "host": ["{{base_url}}"],
              "path": ["backend", "api", "v1", "auth", "verify-email"]
            },
            "description": "Verify user email using verification token"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"oldpassword123\",\n  \"new_password\": \"newpassword123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/backend/api/v1/auth/change-password",
              "host": ["{{base_url}}"],
              "path": ["backend", "api", "v1", "auth", "change-password"]
            },
            "description": "Change user password (requires authentication)"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string",
      "description": "Base URL for the API"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string",
      "description": "JWT token obtained from login endpoint"
    }
  ]
}
